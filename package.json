{
  "name": "linge-serein",
  "version": "0.0.1",
  "private": true,
  "description": "Linge Serein — Service B2B de location de linge hôtelier",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:migrate": "dotenv -- npm run -w packages/database migrate",
    "db:generate": "dotenv -- npm run -w packages/database generate",
    "db:studio": "dotenv -- npm run -w packages/database studio",
    "db:seed": "dotenv -- npm run -w packages/database seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.4.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.3",
  "overrides": {}
}
