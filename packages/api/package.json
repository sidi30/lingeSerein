    "@fastify/swagger-ui": "^5.0.0",
    "@lingengo/database": "*",
    "@lingengo/shared": "*",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.0.0",
