# Exemple d'environnement PROD de l'API (packages/api/.env sur le VPS).
# Le vrai fichier .env n'est JAMAIS commité — secrets générés au déploiement.
# POSTGRES_PASSWORD sert à la fois à l'interpolation compose et est inliné dans DATABASE_URL.
NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0

POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://lingeserein:CHANGE_ME@ls-postgres:5432/lingeserein?schema=public
REDIS_URL=redis://ls-redis:6379

# 32+ caractères chacun
JWT_ACCESS_SECRET=CHANGE_ME_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars
# Exactement 32 caractères (AES-256)
ENCRYPTION_KEY=CHANGE_ME_exactly_32_characters!!

API_URL=https://api.lingeserein.fr
ADMIN_WEB_URL=https://lingeserein.fr
MOBILE_WEB_URL=https://lingeserein.fr
