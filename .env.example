# ============================================
# Lingengo — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# --- Base de données ---
DATABASE_URL="postgresql://lingengo:lingengo_dev@localhost:5432/lingengo?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# --- JWT ---
JWT_ACCESS_SECRET="CHANGE_ME_access_secret_min_32_chars"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret_min_32_chars"

# --- Chiffrement AES-256 (données sensibles en base) ---
ENCRYPTION_KEY="CHANGE_ME_exactly_32_characters!"

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- Resend (emails transactionnels) ---
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@lingengo.fr"

# --- Google Maps ---
GOOGLE_MAPS_API_KEY="AIza..."

# --- Expo Push Notifications ---
EXPO_ACCESS_TOKEN=""

# --- Stockage S3 (OVH Object Storage / Scaleway) ---
S3_ENDPOINT="https://s3.fr-par.scw.cloud"
S3_BUCKET="lingengo-uploads"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="fr-par"

# --- Sentry (monitoring erreurs) ---
SENTRY_DSN=""

# --- App URLs ---
ADMIN_WEB_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# --- Mobile (Expo) ---
EXPO_PUBLIC_API_URL="http://localhost:3001"

# --- RGPD ---
DPO_EMAIL="dpo@lingengo.fr"
