{
  "expo": {
    "name": "Linge Serein",
    "slug": "linge-serein",
    "owner": "sidi30",
    "version": "0.2.1",
    "scheme": "linge-serein",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "fr.linge-serein.app",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false,
        "googleMapsApiKey": ""
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Linge Serein utilise votre position pour afficher la carte de votre tournée de livraison."
      }
    },
    "android": {
      "package": "fr.lingeserein.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Linge Serein utilise votre position pour afficher la carte de votre tournée de livraison."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f4bf7b3-dd98-4acc-a865-cb189852817b"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7f4bf7b3-dd98-4acc-a865-cb189852817b"
    }
  }
}
