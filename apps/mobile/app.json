{
  "expo": {
    "name": "Linge Serein",
    "slug": "linge-serein",
    "owner": "sidi30",
    "version": "0.1.0",
    "scheme": "linge-serein",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "fr.linge-serein.app",
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "fr.linge-serein.app",
      "usesCleartextTraffic": false,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f4bf7b3-dd98-4acc-a865-cb189852817b"
      }
    }
  }
}
