# Compte Gmail expéditeur (et destinataire des notifications de devis).
GMAIL_USER=lingeserein@gmail.com

# IMPORTANT : ce DOIT être un "App Password" Google (16 caractères, format
# "xxxx xxxx xxxx xxxx"), PAS le mot de passe habituel du compte.
# - La validation en 2 étapes (2FA) doit être activée sur le compte Google.
# - Générer ici : https://myaccount.google.com/apppasswords
# Un mot de passe classique échouera avec :
#   534-5.7.9 Application-specific password required
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Origines autorisées (CORS). Liste séparée par des virgules.
# Le site répond sur l'apex ET le www via Traefik.
ALLOWED_ORIGIN=https://lingeserein.fr,https://www.lingeserein.fr

# Port d'écoute interne du conteneur (Traefik route vers ce port).
# NB : le mailer se connecte à Gmail en SORTIE sur le port 587 (STARTTLS) ;
# les ports 25 et 465 sont bloqués en sortie sur le VPS de prod.
PORT=3010

# ─── Inbox admin des demandes de devis ───
# Identifiants HTTP Basic protégeant /admin/devis (api.lingeserein.fr/admin/devis).
# Choisir un mot de passe long et unique. Sans ces deux variables, l'inbox
# renvoie 503 (désactivée).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-long-random

# Répertoire de stockage des demandes (fichier JSONL). Monté en volume Docker
# pour survivre aux redéploiements. Défaut : /data
DATA_DIR=/data
